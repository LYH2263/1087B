generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum BookStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  COMPLETED
  CANCELED
  REFUNDED
}

enum FlashSaleStatus {
  UPCOMING
  ONGOING
  ENDED
}

enum InvoiceStatus {
  PENDING
  ISSUED
  REJECTED
}

enum InvoiceTitleType {
  PERSONAL
  ENTERPRISE
}

enum BookListStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PaymentMethod {
  WECHAT
  ALIPAY
  CARD
  COD
}

model User {
  id           String          @id @default(cuid())
  username     String          @unique
  email        String          @unique
  phone        String          @unique
  passwordHash String
  role         Role            @default(USER)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  sessions     Session[]
  addresses    Address[]
  cartItems    CartItem[]
  orders       Order[]
  passwordResets PasswordReset[]
  flashSaleOrders FlashSaleOrder[]
  invoices Invoice[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  books     Book[]
}

model Book {
  id          String         @id @default(cuid())
  title       String
  author      String
  isbn        String         @unique
  description String
  priceCents  Int
  stock       Int
  coverUrl    String
  sales       Int            @default(0)
  status      BookStatus     @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  cartItems   CartItem[]
  orderItems  OrderItem[]
  flashSales  FlashSale[]
  listItems   BookListItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  recipient    String
  phone        String
  line1        String
  city         String
  state        String
  postalCode   String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Order {
  id            String       @id @default(cuid())
  userId        String
  status        OrderStatus  @default(PENDING_PAYMENT)
  paymentMethod PaymentMethod
  totalCents    Int
  recipient     String
  phone         String
  line1         String
  city          String
  state         String
  postalCode    String
  rating        Int?
  reviewText    String?
  reviewedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id])
  items         OrderItem[]
  flashSaleOrder FlashSaleOrder?
  invoice       Invoice?
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  bookId    String
  title     String
  author    String
  coverUrl  String
  priceCents Int
  quantity  Int
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])
}

model FlashSale {
  id           String   @id @default(cuid())
  bookId       String
  book         Book     @relation(fields: [bookId], references: [id])
  salePriceCents Int
  stock        Int
  soldCount    Int      @default(0)
  startTime    DateTime
  endTime      DateTime
  perUserLimit Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       FlashSaleOrder[]

  @@index([startTime, endTime])
}

model FlashSaleOrder {
  id           String     @id @default(cuid())
  flashSaleId  String
  userId       String
  quantity     Int
  orderId      String?    @unique
  createdAt    DateTime   @default(now())
  flashSale    FlashSale  @relation(fields: [flashSaleId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  order        Order?     @relation(fields: [orderId], references: [id])

  @@unique([flashSaleId, userId])
  @@index([flashSaleId])
  @@index([userId])
}

model Invoice {
  id             String           @id @default(cuid())
  orderId        String           @unique
  userId         String
  status         InvoiceStatus    @default(PENDING)
  titleType      InvoiceTitleType
  titleName      String
  taxNumber      String?
  email          String
  invoiceNumber  String?
  invoiceContent String?
  pdfUrl         String?
  rejectReason   String?
  issuedAt       DateTime?
  rejectedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  order          Order            @relation(fields: [orderId], references: [id])
  user           User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model BookList {
  id          String           @id @default(cuid())
  title       String
  coverUrl    String
  description String
  sortOrder   Int              @default(0)
  status      BookListStatus   @default(DRAFT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       BookListItem[]

  @@index([status, sortOrder])
}

model BookListItem {
  id         String   @id @default(cuid())
  bookListId String
  bookId     String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  bookList   BookList @relation(fields: [bookListId], references: [id], onDelete: Cascade)
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookListId, bookId])
  @@index([bookListId, sortOrder])
}
