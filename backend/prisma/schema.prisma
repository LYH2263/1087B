generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum BookStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  COMPLETED
  CANCELED
  REFUNDED
}

enum FlashSaleStatus {
  UPCOMING
  ONGOING
  ENDED
}

enum InvoiceStatus {
  PENDING
  ISSUED
  REJECTED
}

enum InvoiceTitleType {
  PERSONAL
  ENTERPRISE
}

enum BookListStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PreSaleStatus {
  UPCOMING
  ONGOING
  ARRIVED
  ENDED
}

enum PreSaleReservationStatus {
  PENDING
  NOTIFIED
  FULFILLED
  CANCELED
}

enum NotificationType {
  PRE_SALE_ARRIVAL
  SYSTEM
  ORDER
}

enum PaymentMethod {
  WECHAT
  ALIPAY
  CARD
  COD
}

model User {
  id           String          @id @default(cuid())
  username     String          @unique
  email        String          @unique
  phone        String          @unique
  passwordHash String
  role         Role            @default(USER)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  sessions     Session[]
  addresses    Address[]
  cartItems    CartItem[]
  orders       Order[]
  passwordResets PasswordReset[]
  flashSaleOrders FlashSaleOrder[]
  invoices Invoice[]
  questions    Question[]
  answers      Answer[]
  answerLikes  AnswerLike[]
  reviewLikes  ReviewLike[]
  preSaleReservations PreSaleReservation[]
  notifications Notification[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  books     Book[]
}

model Book {
  id          String         @id @default(cuid())
  title       String
  author      String
  isbn        String         @unique
  description String
  priceCents  Int
  stock       Int
  coverUrl    String
  sales       Int            @default(0)
  status      BookStatus     @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  cartItems   CartItem[]
  orderItems  OrderItem[]
  flashSales  FlashSale[]
  listItems   BookListItem[]
  questions   Question[]
  tags        BookTag[]
  preSale     PreSale?
  preSaleReservations PreSaleReservation[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())
  books     BookTag[]
}

model BookTag {
  id        String   @id @default(cuid())
  bookId    String
  tagId     String
  createdAt DateTime @default(now())
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([bookId, tagId])
  @@index([bookId])
  @@index([tagId])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  recipient    String
  phone        String
  line1        String
  city         String
  state        String
  postalCode   String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

enum ShippingRuleType {
  FIXED
  PER_ITEM
}

model ShippingRule {
  id              String          @id @default(cuid())
  name            String
  type            ShippingRuleType @default(FIXED)
  feeCents        Int
  freeThresholdCents Int?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([isActive])
}

model Order {
  id            String       @id @default(cuid())
  userId        String
  status        OrderStatus  @default(PENDING_PAYMENT)
  paymentMethod PaymentMethod
  totalCents    Int
  shippingCents Int          @default(0)
  recipient     String
  phone         String
  line1         String
  city          String
  state         String
  postalCode    String
  rating        Int?
  reviewText    String?
  reviewedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id])
  items         OrderItem[]
  reviewImageUrls String[]
  reviewLikes    ReviewLike[]
  flashSaleOrder FlashSaleOrder?
  invoice       Invoice?
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  bookId    String
  title     String
  author    String
  coverUrl  String
  priceCents Int
  quantity  Int
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])
}

model FlashSale {
  id           String   @id @default(cuid())
  bookId       String
  book         Book     @relation(fields: [bookId], references: [id])
  salePriceCents Int
  stock        Int
  soldCount    Int      @default(0)
  startTime    DateTime
  endTime      DateTime
  perUserLimit Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       FlashSaleOrder[]

  @@index([startTime, endTime])
}

model FlashSaleOrder {
  id           String     @id @default(cuid())
  flashSaleId  String
  userId       String
  quantity     Int
  orderId      String?    @unique
  createdAt    DateTime   @default(now())
  flashSale    FlashSale  @relation(fields: [flashSaleId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  order        Order?     @relation(fields: [orderId], references: [id])

  @@unique([flashSaleId, userId])
  @@index([flashSaleId])
  @@index([userId])
}

model Invoice {
  id             String           @id @default(cuid())
  orderId        String           @unique
  userId         String
  status         InvoiceStatus    @default(PENDING)
  titleType      InvoiceTitleType
  titleName      String
  taxNumber      String?
  email          String
  invoiceNumber  String?
  invoiceContent String?
  pdfUrl         String?
  rejectReason   String?
  issuedAt       DateTime?
  rejectedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  order          Order            @relation(fields: [orderId], references: [id])
  user           User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model BookList {
  id          String           @id @default(cuid())
  title       String
  coverUrl    String
  description String
  sortOrder   Int              @default(0)
  status      BookListStatus   @default(DRAFT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       BookListItem[]

  @@index([status, sortOrder])
}

model BookListItem {
  id         String   @id @default(cuid())
  bookListId String
  bookId     String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  bookList   BookList @relation(fields: [bookListId], references: [id], onDelete: Cascade)
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookListId, bookId])
  @@index([bookListId, sortOrder])
}

model Question {
  id        String   @id @default(cuid())
  bookId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   Answer[]

  @@index([bookId, createdAt])
  @@index([userId])
}

model Answer {
  id        String       @id @default(cuid())
  questionId String
  userId    String
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  question  Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     AnswerLike[]

  @@index([questionId, createdAt])
  @@index([userId])
}

model AnswerLike {
  id        String   @id @default(cuid())
  answerId  String
  userId    String
  createdAt DateTime @default(now())
  answer    Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([answerId, userId])
  @@index([answerId])
  @@index([userId])
}

model PreSale {
  id                String              @id @default(cuid())
  bookId            String              @unique
  book              Book                @relation(fields: [bookId], references: [id], onDelete: Cascade)
  expectedArrivalDate DateTime
  preSaleStock      Int
  reservationCount  Int                 @default(0)
  status            PreSaleStatus       @default(UPCOMING)
  arrivedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  reservations      PreSaleReservation[]

  @@index([status])
  @@index([expectedArrivalDate])
}

model PreSaleReservation {
  id        String                   @id @default(cuid())
  preSaleId String
  userId    String
  bookId    String
  status    PreSaleReservationStatus @default(PENDING)
  notifiedAt DateTime?
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  preSale   PreSale                  @relation(fields: [preSaleId], references: [id], onDelete: Cascade)
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book                     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([preSaleId, userId])
  @@index([preSaleId])
  @@index([userId])
  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String
  relatedId String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model ReviewLike {
  id        String   @id @default(cuid())
  orderId   String
  userId    String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orderId, userId])
  @@index([orderId])
  @@index([userId])
}
